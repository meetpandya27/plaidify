{
  "schema_version": "2.0",
  "name": "Internal Browser Fixture",
  "domain": "localhost:8080",
  "tags": ["internal", "fixture", "browser"],
  "auth": {
    "type": "form",
    "steps": [
      {
        "action": "goto",
        "url": "http://localhost:8080/login"
      },
      {
        "action": "fill",
        "selector": "#username",
        "value": "{{username}}"
      },
      {
        "action": "fill",
        "selector": "#password",
        "value": "{{password}}"
      },
      {
        "action": "click",
        "selector": "#login-btn",
        "wait_for_navigation": true
      },
      {
        "action": "wait",
        "selector": "#dashboard, #otp-input",
        "timeout": 10000
      }
    ]
  },
  "mfa": {
    "detection": {
      "selector": "#otp-input",
      "timeout": 3000
    },
    "type": "otp_input",
    "handler": "user_prompt",
    "input_selector": "#otp-input",
    "submit_selector": "#otp-submit"
  },
  "extract": {
    "current_bill": {
      "selector": "#current-bill",
      "type": "currency",
      "transform": "strip_dollar_sign"
    },
    "usage_kwh": {
      "selector": "#usage-kwh",
      "type": "text"
    },
    "account_number": {
      "selector": "#account-number",
      "type": "text",
      "sensitive": true
    },
    "account_status": {
      "selector": "#account-status",
      "type": "text"
    },
    "service_address": {
      "selector": "#service-address",
      "type": "text"
    },
    "plan_name": {
      "selector": "#plan-name",
      "type": "text"
    },
    "meter_id": {
      "selector": "#meter-id",
      "type": "text"
    },
    "next_read_date": {
      "selector": "#next-read-date",
      "type": "date"
    },
    "customer_name": {
      "selector": "#customer-name",
      "type": "text"
    },
    "customer_email": {
      "selector": "#customer-email",
      "type": "email"
    },
    "usage_history": {
      "selector": ".usage-row",
      "type": "list",
      "fields": {
        "month": {
          "selector": ".usage-month",
          "type": "text"
        },
        "kwh": {
          "selector": ".usage-kwh-val",
          "type": "number",
          "transform": "strip_commas"
        },
        "cost": {
          "selector": ".usage-cost",
          "type": "currency",
          "transform": "strip_dollar_sign"
        },
        "avg_temp": {
          "selector": ".usage-temp",
          "type": "text"
        }
      }
    },
    "payments": {
      "selector": ".payment-row",
      "type": "list",
      "fields": {
        "date": {
          "selector": ".payment-date",
          "type": "date"
        },
        "description": {
          "selector": ".payment-desc",
          "type": "text"
        },
        "amount": {
          "selector": ".payment-amount",
          "type": "currency",
          "transform": "strip_dollar_sign"
        },
        "status": {
          "selector": ".payment-status",
          "type": "text"
        }
      }
    }
  },
  "cleanup": [
    {
      "action": "click",
      "selector": "#logout-btn"
    }
  ],
  "rate_limit": {
    "max_requests_per_hour": 60,
    "min_interval_seconds": 5
  },
  "health_check": {
    "url": "http://localhost:8080/health",
    "expected_status": 200
  }
}