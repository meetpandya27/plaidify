# ══════════════════════════════════════════════════════════════════════════════
# Plaidify — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values before running the app.
#
#   cp .env.example .env
#
# Public repo note:
# Keep real Azure production values in GitHub environment secrets/variables and
# Azure Key Vault. Do not commit live credentials, connection strings, or
# subscription-specific settings to this repository.
#
# REQUIRED variables have no default and will cause a startup error if missing.
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED: Encryption Key ─────────────────────────────────────────────────
# 256-bit key for AES-256-GCM credential encryption (base64url-encoded).
# Generate with:
#   python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# Previous encryption key for key rotation (base64url-encoded).
# Set this when rotating ENCRYPTION_KEY so old data can still be decrypted.
# ENCRYPTION_KEY_PREVIOUS=
# ENCRYPTION_KEY_VERSION=1

# ── REQUIRED: JWT Secret ─────────────────────────────────────────────────────
# Secret key for signing JWT access tokens.
# Generate with:
#   openssl rand -hex 32
JWT_SECRET_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# SQLAlchemy connection string. SQLite for development, PostgreSQL for production.
# In Azure production, this is typically injected from Key Vault at deploy time.
# DATABASE_URL=sqlite:///plaidify.db
# DATABASE_URL=postgresql://user:password@localhost:5432/plaidify
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=3600

# ── Docker Compose Postgres (used by docker-compose.yml) ────────────────────
# POSTGRES_USER=plaidify
POSTGRES_PASSWORD=
# POSTGRES_DB=plaidify

# ── Redis ────────────────────────────────────────────────────────────────────
# In Azure production, this is typically injected from Key Vault at deploy time.
# Required for multi-worker deployments (shared RSA keys, rate limiting).
# REDIS_URL=redis://localhost:6379/0

# ── Server ───────────────────────────────────────────────────────────────────
# ENV=development          # 'development', 'staging', or 'production'
# APP_NAME=Plaidify
# APP_VERSION=0.3.0b1
# DEBUG=false
# ENFORCE_HTTPS=false      # Set true in production (behind TLS proxy)

# ── Registration & Bootstrap ─────────────────────────────────────────────────
# Disable public self-registration in production and provision the first
# account via the bootstrap settings (created on startup, idempotent).
# REGISTRATION_ENABLED=true
# BOOTSTRAP_USER_USERNAME=admin
# BOOTSTRAP_USER_EMAIL=admin@example.com
# BOOTSTRAP_USER_PASSWORD=        # supply via secret store, not source control

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json   # 'json' for production, 'text' for development

# ── Observability ────────────────────────────────────────────────────────────
# Sentry DSN for error tracking. Leave unset to disable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# OpenTelemetry OTLP endpoint for distributed tracing. Leave unset to disable.
# OTEL_ENDPOINT=http://localhost:4317

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use specific origins in production.
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# ── Hosted Link ───────────────────────────────────────────────────────────────
# PUBLIC_LINK_SESSIONS_ENABLED=false
# PUBLIC_LINK_ALLOWED_ORIGINS=https://app.example.com
# LINK_LAUNCH_TOKEN_EXPIRE_SECONDS=300

# ── Rate Limiting ────────────────────────────────────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_AUTH=5/minute
# RATE_LIMIT_CONNECT=10/minute
# RATE_LIMIT_MFA=5/minute      # Per-IP cap on POST /mfa/submit (brute-force guard)
# RATE_LIMIT_DEFAULT=60/minute
# HEALTH_CHECK_TOKEN=

# ── Detached Access Jobs ────────────────────────────────────────────────────
# ACCESS_JOB_EXECUTION_MODE=inprocess    # 'inprocess' for dev, 'redis-worker' for separate executors
# ACCESS_JOB_WORKER_CONCURRENCY=2

# ── Demo / Sandbox ───────────────────────────────────────────────────────────
# Surfaces the bundled 'demo_utility' connector on discovery surfaces so the
# full connect → MFA → extract loop can be run end-to-end against the bundled
# demo portal (src/demo/portal.py). Keep this OFF in production.
# DEMO_MODE=true
# DEMO_PORTAL_URL=http://127.0.0.1:8799

# ── Browser Engine ───────────────────────────────────────────────────────────
# BROWSER_HEADLESS=true
# BROWSER_POOL_SIZE=5
# BROWSER_IDLE_TIMEOUT=300
# BROWSER_NAVIGATION_TIMEOUT=30000
# BROWSER_ACTION_TIMEOUT=10000
# BROWSER_BLOCK_RESOURCES=true
# BROWSER_STEALTH=true
# STRICT_READ_ONLY_MODE=true
# BROWSER_ALLOW_READ_DOWNLOADS=true
# BROWSER_DOWNLOAD_ROOT=/tmp/plaidify-downloads

# ── LLM Extraction (optional) ───────────────────────────────────────────────
# LLM_PROVIDER=openai       # 'openai' or 'anthropic'
# LLM_API_KEY=
# LLM_MODEL=                # e.g. gpt-4o, claude-sonnet-4-20250514
# LLM_BASE_URL=
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.0
