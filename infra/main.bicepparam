using './main.bicep'

param namePrefix = 'plaidify'
param environmentName = 'production'
param location = 'eastus2'
param appEnv = 'production'
param appName = 'Plaidify'
param appVersion = '0.3.0b1'
param corsOrigins = 'https://example.com'
param logLevel = 'INFO'
param logFormat = 'json'
param enforceHttps = true
param llmProvider = 'openai'
param llmModel = ''
param deployApplication = false
param containerImage = 'mcr.microsoft.com/azuredocs/containerapps-helloworld:latest'
param containerCpu = '0.5'
param containerMemory = '1Gi'
param minReplicas = 1
param maxReplicas = 3
param accessExecutorContainerCpu = '0.5'
param accessExecutorContainerMemory = '1Gi'
param accessExecutorMinReplicas = 1
param accessExecutorMaxReplicas = 1
param accessJobWorkerConcurrency = 2
param migrationJobCpu = '0.5'
param migrationJobMemory = '1Gi'
param migrationReplicaTimeout = 1800
param postgresAdminLogin = 'replace-at-deploy-time'
param postgresAdminPassword = 'replace-at-deploy-time'
param postgresSkuName = 'B_Standard_B1ms'
param postgresSkuTier = 'Burstable'
param postgresVersion = '16'
param postgresStorageSizeGB = 32
param postgresDatabaseName = 'plaidify'
param logAnalyticsRetentionInDays = 30
param redisSkuName = 'Basic'
param redisSkuFamily = 'C'
param redisSkuCapacity = 0
param enableLlmApiKeySecret = false
param enableHealthCheckTokenSecret = false