# Plaidify production environment template
# Copy to .env.production and fill in the values before starting the production stack.

# Required secrets
ENCRYPTION_KEY=
JWT_SECRET_KEY=

# Recommended server settings
APP_NAME=Plaidify
APP_VERSION=0.3.0b1
ENV=production
DEBUG=false
ENFORCE_HTTPS=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# Networking and browser limits
CORS_ORIGINS=https://app.example.com
PUBLIC_LINK_SESSIONS_ENABLED=false
# PUBLIC_LINK_ALLOWED_ORIGINS=https://app.example.com
# LINK_LAUNCH_TOKEN_EXPIRE_SECONDS=300
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=5
BROWSER_IDLE_TIMEOUT=300
BROWSER_NAVIGATION_TIMEOUT=30000
BROWSER_ACTION_TIMEOUT=10000
STRICT_READ_ONLY_MODE=true

# Optional observability
SENTRY_DSN=
OTEL_ENDPOINT=
HEALTH_CHECK_TOKEN=

# Optional LLM extraction
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=

# Gunicorn tuning
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# Detached access job executor
ACCESS_JOB_EXECUTION_MODE=redis-worker
ACCESS_JOB_WORKER_CONCURRENCY=2

# Database naming
POSTGRES_USER=plaidify
POSTGRES_DB=plaidify

# Optional image override when pulling from a registry
# PLAIDIFY_IMAGE=ghcr.io/your-org/plaidify:latest